OPENAI_API_KEY=<openai-api-key>
ANTHROPIC_API_KEY=<anthropic-api-key>
GOOGLE_API_KEY=<google-api-key>
GIOTTO_CLIENT_ID=<giotto-keycloak-client-id>
GIOTTO_CLIENT_SECRET=<giotto-keycloak-client-secret>
LANGFUSE_SECRET_KEY=zeno-secret-key-123
LANGFUSE_PUBLIC_KEY=zeno-public-key-123
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_TRACING_ENABLED=true

MAPBOX_API_TOKEN=<mapbox-api-key>
WRI_API_KEY=<wri-api-key>
WRI_BEARER_TOKEN=<wri-bearer-token>
API_BASE_URL=http://localhost:8000
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/zeno-data-local
COOKIE_SIGNER_SECRET_KEY="secret-cookie-key-123"
DATASET_EMBEDDINGS_DB=<name-of-dataset-embeddings-db>
# Model Configuration
# Available options: sonnet, haiku, gemini, gemini-flash, gemini-flash-lite, giotto
MODEL=gemini
SMALL_MODEL=gemini-flash
FALLBACK_MODELS=gemini-flash,gemini-flash-lite
CODING_MODEL=gemini-3.1-pro-preview # Full Google model IDs required (used by genai SDK directly, not LangChain)
CODING_FALLBACK_MODELS=gemini-2.5-pro,gemini-3-flash-preview # Full Google model IDs required
EOAPI_BASE_URL=https://eoapi-cache.globalnaturewatch.org

# Sentinel-2 mosaic storage. Built MosaicJSON files are written to this private
# S3 bucket. AWS credentials come from the standard boto3 chain
# (IAM role / env / profile).
MOSAIC_S3_BUCKET=<mosaic-bucket-name>
MOSAIC_S3_PREFIX=mosaics
MOSAIC_S3_REGION=us-west-2
# Optional: external titiler that reads the mosaics from S3 via s3://. Leave
# unset to have this app serve tiles itself from S3 at /mosaic/...
MOSAIC_TILER_URL=

# Logging Configuration
LOG_LEVEL=INFO              # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=text             # text (colored) or json (structured)
LOG_VERBOSE=true            # false = compact console (no query/request_id/thread_id)
LOG_TO_FILE=true            # write logs to file
LOG_FILE_PATH=logs/zeno.log # log file location

# Test Database connection - for development only
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5434/zeno-data_test
